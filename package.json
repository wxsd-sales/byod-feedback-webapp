{
  "name": "byod-feedback-webapp",
  "version": "1.0.0",
  "description": "Example Web App for collecting feedback from users on Cisco BYOD Devices",
  "type": "module",
  "scripts": {
    "serve:web": "node scripts/serve-web.mjs",
    "screenshot:web": "node scripts/screenshot-web.mjs",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest --runInBand",
    "test:watch": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" jest --watchAll --runInBand"
  },
  "keywords": [
    "cisco",
    "collaboration",
    "macro",
    "webapp"
  ],
  "author": "William Mills",
  "license": "MIT",
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-mock-xapi": "^1.0.5"
  },
    "jest": {
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^xapi$": "jest-mock-xapi"
    }
  }
}
